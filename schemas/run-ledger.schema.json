{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://luminarylabs.dev/schemas/nexusagent/run-ledger.schema.json",
  "title": "NexusAgent Run Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "created_at", "goal", "action", "status"],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "passed", "failed", "paused", "finalized"]
    },
    "workspace_root": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_step": {
      "type": "string"
    }
  }
}
